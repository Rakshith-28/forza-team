// =============================================================================
// MODULE: evaluations — templates, criteria, weights, cycles, scores    §7.40–7.48
// =============================================================================

model EvaluationTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String   @map("club_id") @db.Uuid
  name        String   @db.VarChar(150)
  description String?
  status      String   @default("ACTIVE") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?  @map("created_by") @db.Uuid
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?  @map("updated_by") @db.Uuid

  club                   Club                    @relation(fields: [clubId], references: [id])
  criteria               EvaluationCriterion[]
  positionWeightProfiles PositionWeightProfile[]
  playerEvaluations      PlayerEvaluation[]

  @@map("evaluation_templates")
}

model EvaluationCriterion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  code       String   @db.VarChar(100)
  label      String   @db.VarChar(150)
  sortOrder  Int      @map("sort_order")
  minScore   Decimal  @default(0) @map("min_score") @db.Decimal(5, 2)
  maxScore   Decimal  @default(10) @map("max_score") @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  template         EvaluationTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  weightItems      PositionWeightProfileItem[]
  evaluationScores PlayerEvaluationScore[]

  @@unique([templateId, code], name: "uq_evaluation_criteria_template_code")
  @@map("evaluation_criteria")
}

model PositionWeightProfile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId        String    @map("club_id") @db.Uuid
  templateId    String    @map("template_id") @db.Uuid
  positionCode  String    @map("position_code") @db.VarChar(50)
  totalWeight   Decimal   @default(0) @map("total_weight") @db.Decimal(8, 2)
  isDefault     Boolean   @default(false) @map("is_default")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy     String?   @map("updated_by") @db.Uuid

  club     Club                        @relation(fields: [clubId], references: [id])
  template EvaluationTemplate          @relation(fields: [templateId], references: [id])
  items    PositionWeightProfileItem[]

  @@unique([clubId, templateId, positionCode, effectiveFrom], name: "uq_position_weight_profiles")
  @@index([clubId])
  @@index([templateId])
  @@index([positionCode])
  @@map("position_weight_profiles")
}

model PositionWeightProfileItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId   String  @map("profile_id") @db.Uuid
  criterionId String  @map("criterion_id") @db.Uuid
  weight      Decimal @db.Decimal(8, 2)

  profile   PositionWeightProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  criterion EvaluationCriterion   @relation(fields: [criterionId], references: [id])

  @@unique([profileId, criterionId], name: "uq_position_weight_profile_item")
  @@map("position_weight_profile_items")
}

model EvaluationCycle {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  teamId    String?  @map("team_id") @db.Uuid
  seasonId  String?  @map("season_id") @db.Uuid
  name      String   @db.VarChar(150)
  cycleType String   @map("cycle_type") @db.VarChar(50)
  startsAt  DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime @map("ends_at") @db.Timestamptz(6)
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid

  club              Club               @relation(fields: [clubId], references: [id])
  team              Team?              @relation(fields: [teamId], references: [id])
  season            Season?            @relation(fields: [seasonId], references: [id])
  playerEvaluations PlayerEvaluation[]

  @@index([clubId])
  @@index([teamId])
  @@index([seasonId])
  @@map("evaluation_cycles")
}

model PlayerEvaluation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String   @map("club_id") @db.Uuid
  teamId             String   @map("team_id") @db.Uuid
  playerId           String   @map("player_id") @db.Uuid
  evaluationCycleId  String   @map("evaluation_cycle_id") @db.Uuid
  templateId         String   @map("template_id") @db.Uuid
  positionCode       String   @map("position_code") @db.VarChar(50)
  overallScore       Decimal  @map("overall_score") @db.Decimal(8, 2)
  rankInScope        Int?     @map("rank_in_scope")
  bucketLabel        String?  @map("bucket_label") @db.VarChar(50)
  summaryComment     String?  @map("summary_comment")
  coachOnlyNotes     String?  @map("coach_only_notes")
  playerVisibleNotes String?  @map("player_visible_notes")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy          String?  @map("created_by") @db.Uuid
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy          String?  @map("updated_by") @db.Uuid

  club            Club                    @relation(fields: [clubId], references: [id])
  team            Team                    @relation(fields: [teamId], references: [id])
  player          Player                  @relation(fields: [playerId], references: [id])
  evaluationCycle EvaluationCycle         @relation(fields: [evaluationCycleId], references: [id])
  template        EvaluationTemplate      @relation(fields: [templateId], references: [id])
  scores          PlayerEvaluationScore[]

  @@unique([playerId, evaluationCycleId, templateId], name: "uq_player_evaluations")
  @@index([clubId])
  @@index([teamId])
  @@index([playerId])
  @@index([evaluationCycleId])
  @@index([overallScore(sort: Desc)])
  @@map("player_evaluations")
}

model PlayerEvaluationScore {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerEvaluationId String  @map("player_evaluation_id") @db.Uuid
  criterionId        String  @map("criterion_id") @db.Uuid
  rawScore           Decimal @map("raw_score") @db.Decimal(8, 2)
  weightedScore      Decimal @map("weighted_score") @db.Decimal(8, 2)

  playerEvaluation PlayerEvaluation    @relation(fields: [playerEvaluationId], references: [id], onDelete: Cascade)
  criterion        EvaluationCriterion @relation(fields: [criterionId], references: [id])

  @@unique([playerEvaluationId, criterionId], name: "uq_player_evaluation_score")
  @@index([playerEvaluationId])
  @@index([criterionId])
  @@map("player_evaluation_scores")
}

model DevelopmentGoal {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  playerId    String    @map("player_id") @db.Uuid
  teamId      String?   @map("team_id") @db.Uuid
  title       String    @db.VarChar(200)
  description String?
  category    String?   @db.VarChar(100)
  status      String    @default("OPEN") @db.VarChar(50)
  visibility  String    @default("COACH_ONLY") @db.VarChar(50)
  targetDate  DateTime? @map("target_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?   @map("updated_by") @db.Uuid

  club    Club                    @relation(fields: [clubId], references: [id])
  player  Player                  @relation(fields: [playerId], references: [id])
  team    Team?                   @relation(fields: [teamId], references: [id])
  updates DevelopmentGoalUpdate[]

  @@index([clubId])
  @@index([playerId])
