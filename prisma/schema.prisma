model Event {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String    @map("club_id") @db.Uuid
  /// DEPRECATED — do NOT read. Event audience is resolved via `audienceScope`
  /// + `EventTeam` rows (see modules/events). Kept nullable for back-compat;
  /// to be dropped in a follow-up migration.
  teamId       String?   @map("team_id") @db.Uuid
  /// Canonical audience: "CLUB_WIDE" (everyone in the club) or "TEAMS" (only
  /// actors whose teams intersect this event's EventTeam rows).
  audienceScope String   @default("TEAMS") @map("audience_scope") @db.VarChar(20)
  eventType    String    @map("event_type") @db.VarChar(50)
  title        String    @db.VarChar(200)
  description  String?
  startAt      DateTime  @map("start_at") @db.Timestamptz(6)
  endAt        DateTime  @map("end_at") @db.Timestamptz(6)
  timezone     String    @db.VarChar(100)
  locationName String?   @map("location_name") @db.VarChar(200)
  addressLine1 String?   @map("address_line1") @db.VarChar(200)
  city         String?   @db.VarChar(100)
  state        String?   @db.VarChar(100)
  postalCode   String?   @map("postal_code") @db.VarChar(20)
  opponentName String?   @map("opponent_name") @db.VarChar(200)
  homeAway     String?   @map("home_away") @db.VarChar(20)
  arrivalTime  DateTime? @map("arrival_time") @db.Timestamptz(6)
  uniformNotes String?   @map("uniform_notes")
  status       String    @default("SCHEDULED") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?   @map("updated_by") @db.Uuid

  club              Club               @relation(fields: [clubId], references: [id])
  team              Team?              @relation(fields: [teamId], references: [id])
