model DevelopmentGoalUpdate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId         String   @map("goal_id") @db.Uuid
  progressStatus String   @map("progress_status") @db.VarChar(50)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?  @map("created_by") @db.Uuid

  goal DevelopmentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("development_goal_updates")
}

// =============================================================================
// Platform: notifications & audit (cross-cutting / reporting)           §7.49–7.51
// =============================================================================

model Notification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  clubId          String?   @map("club_id") @db.Uuid
  type            String    @db.VarChar(100)
  title           String    @db.VarChar(200)
  body            String?
  payloadJson     Json?     @map("payload_json")
  deliveryChannel String    @map("delivery_channel") @db.VarChar(30)
  status          String    @default("PENDING") @db.VarChar(50)
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz(6)
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)
  readAt          DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User  @relation(fields: [userId], references: [id])
  club Club? @relation(fields: [clubId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

model NotificationPreference {
  id                               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                           String   @unique @map("user_id") @db.Uuid
  emailEnabled                     Boolean  @default(true) @map("email_enabled")
  pushEnabled                      Boolean  @default(true) @map("push_enabled")
  smsEnabled                       Boolean  @default(false) @map("sms_enabled")
  chatNotificationsEnabled         Boolean  @default(true) @map("chat_notifications_enabled")
  announcementNotificationsEnabled Boolean  @default(true) @map("announcement_notifications_enabled")
  billingNotificationsEnabled      Boolean  @default(true) @map("billing_notifications_enabled")
  scheduleNotificationsEnabled     Boolean  @default(true) @map("schedule_notifications_enabled")
  createdAt                        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String?  @map("club_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String   @db.VarChar(150)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id") @db.Uuid
  metadataJson Json?    @map("metadata_json")
  ipAddress    String?  @map("ip_address") @db.Inet
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  club Club? @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// =============================================================================
// MODULE: master — platform-wide system settings (Master Admin only)
// =============================================================================

// Singleton row of GLOBAL platform settings, distinct from per-club
// `club_settings`. Holds platform-wide master switches and the defaults applied
// to brand-new clubs. Exactly one row exists (id = "system").
model SystemSettings {
  id                         String   @id @default("system")
  aiFeaturesEnabled          Boolean  @default(true) @map("ai_features_enabled")
  maintenanceMode            Boolean  @default(false) @map("maintenance_mode")
  defaultCurrency            String   @default("USD") @map("default_currency") @db.VarChar(10)
  defaultRegistrationEnabled Boolean  @default(true) @map("default_registration_enabled")
  defaultBillingEnabled      Boolean  @default(true) @map("default_billing_enabled")
  defaultSmsNotifications    Boolean  @default(false) @map("default_sms_notifications")
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy                  String?  @map("updated_by") @db.Uuid

  @@map("system_settings")
}

// =============================================================================
// MODULE: platform announcements — Master Admin broadcasts to all tenants
// =============================================================================
// System-scoped (NO club_id): a notice published ABOVE all clubs, distinct from
// the club-scoped `announcements` table and per-user `notifications`. Visibility
// is computed at query time (audience scope + roles); reads are tracked only on
// interaction (no per-user fan-out on publish).

model PlatformAnnouncement {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String    @db.VarChar(200)
  body          String
  severity      String    @default("INFO") @db.VarChar(20) // INFO | WARNING | CRITICAL
  audienceScope String    @default("ALL_CLUBS") @map("audience_scope") @db.VarChar(30) // ALL_CLUBS | SPECIFIC_CLUBS
  audienceRoles String[]  @map("audience_roles") // role codes: CLUB_ADMIN | COACH | PLAYER
  status        String    @default("DRAFT") @db.VarChar(20) // DRAFT | SCHEDULED | PUBLISHED | ARCHIVED
  pinned        Boolean   @default(false)
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)
  scheduledAt   DateTime? @map("scheduled_at") @db.Timestamptz(6)
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy     String?   @map("updated_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?   @map("deleted_by") @db.Uuid

  clubs PlatformAnnouncementClub[]
  reads PlatformAnnouncementRead[]

  @@index([status])
  @@index([publishedAt(sort: Desc)])
  @@index([scheduledAt])
  @@map("platform_announcements")
}

// Targets for audience_scope = SPECIFIC_CLUBS (unused for ALL_CLUBS).
model PlatformAnnouncementClub {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformAnnouncementId String @map("platform_announcement_id") @db.Uuid
  clubId                 String @map("club_id") @db.Uuid

  announcement PlatformAnnouncement @relation(fields: [platformAnnouncementId], references: [id], onDelete: Cascade)
  club         Club                 @relation(fields: [clubId], references: [id])

  @@unique([platformAnnouncementId, clubId], name: "uq_platform_announcement_club")
  @@index([clubId])
  @@map("platform_announcement_clubs")
}

// Read/dismiss tracking — one row per (announcement, user), written on interaction.
model PlatformAnnouncementRead {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformAnnouncementId String    @map("platform_announcement_id") @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  readAt                 DateTime? @map("read_at") @db.Timestamptz(6)
  dismissedAt            DateTime? @map("dismissed_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  announcement PlatformAnnouncement @relation(fields: [platformAnnouncementId], references: [id], onDelete: Cascade)

  @@unique([platformAnnouncementId, userId], name: "uq_platform_announcement_read")
  @@index([userId])
  @@map("platform_announcement_reads")
}

// Reusable composer templates.
model PlatformAnnouncementTemplate {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String   @db.VarChar(150)
  title                String   @db.VarChar(200)
  body                 String
  severity             String   @default("INFO") @db.VarChar(20)
  defaultAudienceScope String   @default("ALL_CLUBS") @map("default_audience_scope") @db.VarChar(30)
  defaultAudienceRoles String[] @map("default_audience_roles")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy            String?  @map("created_by") @db.Uuid
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_announcement_templates")
}
