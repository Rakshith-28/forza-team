// Forza Team — Prisma schema
//
// Ported from docs/soccer_club_database_schema.md (51 tables), organized by the
// domain modules in docs/BUILD_PLAN.md §2. Module ownership is marked with
// banner comments; modules talk through services, never across table internals.
//
// Engineering decisions (faithful to the spec + BUILD_PLAN):
//   • Enum-like columns are controlled strings (`String @db.VarChar(n)`), not
//     Prisma enums — values are validated in the service layer / Zod.
//   • Audit + actor columns (created_by, updated_by, deleted_by, and the various
//     *_by_user_id references) are scalar UUIDs, NOT relations. This avoids ~20
//     ambiguous back-relations on User; "who did this" is resolved in the app.
//   • Identity edges that the row is *about* (user_id, sender_user_id) ARE
//     relations, since RBAC and queries traverse them.
//   • PKs: UUID via gen_random_uuid(). Timestamps: timestamptz. Money: numeric.
//   • snake_case table/column names preserved via @map / @@map.
//   • CHECK constraints from the spec (date ranges, non-negative money, weight
//     totals) are NOT expressible in Prisma schema; they are enforced in the
//     service layer per spec §10/§11.
//   • updated_at mirrors the spec (DEFAULT now()); it is set by the service
//     layer on write (no @updatedAt, matching the SQL which has no trigger).

generator client {
  provider        = "prisma-client"
  output          = "../src/db/generated"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

// =============================================================================
// MODULE: identity — users, roles, sessions (Better Auth glue)            §7.1–7.5
// =============================================================================

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.Citext
  passwordHash    String    @map("password_hash")
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(30)
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz(6)
  status          String    @default("ACTIVE") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  roleAssignments        UserRoleAssignment[]
  teamCoachRoles         TeamCoach[]
  parentProfiles         Parent[]
  chatMemberships        ChatMember[]
  messagesSent           Message[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  passwordResetTokens    PasswordResetToken[]

  @@index([status])
  @@map("users")
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String?

  assignments UserRoleAssignment[]

  @@map("roles")
}

model UserRoleAssignment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  clubId    String?   @map("club_id") @db.Uuid
  teamId    String?   @map("team_id") @db.Uuid
  isPrimary Boolean   @default(false) @map("is_primary")
  status    String    @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  user User  @relation(fields: [userId], references: [id])
  role Role  @relation(fields: [roleId], references: [id])
  club Club? @relation(fields: [clubId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@index([userId])
  @@index([clubId])
  @@index([teamId])
  @@index([roleId])
  @@map("user_role_assignments")
}

model Invitation {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId           String?   @map("club_id") @db.Uuid
  email            String    @db.Citext
  roleCode         String    @map("role_code") @db.VarChar(50)
  teamId           String?   @map("team_id") @db.Uuid
  tokenHash        String    @map("token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt       DateTime? @map("accepted_at") @db.Timestamptz(6)
  acceptedByUserId String?   @map("accepted_by_user_id") @db.Uuid
  status           String    @default("PENDING") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid

  club Club? @relation(fields: [clubId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@index([email])
  @@index([clubId])
  @@index([status])
  @@map("invitations")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

// =============================================================================
// MODULE: clubs — clubs, settings, seasons, teams, coaches               §7.6–7.10
// =============================================================================

model Club {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String    @db.VarChar(200)
  shortCode      String    @unique @map("short_code") @db.VarChar(50)
  logoUrl        String?   @map("logo_url")
  primaryColor   String?   @map("primary_color") @db.VarChar(20)
  secondaryColor String?   @map("secondary_color") @db.VarChar(20)
  addressLine1   String?   @map("address_line1") @db.VarChar(200)
  addressLine2   String?   @map("address_line2") @db.VarChar(200)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  country        String?   @db.VarChar(100)
  phone          String?   @db.VarChar(30)
  website        String?
  timezone       String    @default("America/New_York") @db.VarChar(100)
  status         String    @default("ACTIVE") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?   @map("deleted_by") @db.Uuid

  settings                ClubSetting?
  seasons                 Season[]
  teams                   Team[]
  userRoleAssignments     UserRoleAssignment[]
  invitations             Invitation[]
  teamCoaches             TeamCoach[]
  players                 Player[]
  playerTeamMemberships   PlayerTeamMembership[]
  parents                 Parent[]
  playerParentLinks       PlayerParentLink[]
  files                   File[]
  announcements           Announcement[]
  chats                   Chat[]
  events                  Event[]
  eventRsvps              EventRsvp[]
  attendanceRecords       AttendanceRecord[]
  registrationPrograms    RegistrationProgram[]
  registrationForms       RegistrationForm[]
  registrationSubmissions RegistrationSubmission[]
  familyAccounts          FamilyAccount[]
  discounts               Discount[]
  invoices                Invoice[]
  payments                Payment[]
  refunds                 Refund[]
  waivers                 Waiver[]
  waiverAcceptances       WaiverAcceptance[]
  evaluationTemplates     EvaluationTemplate[]
  positionWeightProfiles  PositionWeightProfile[]
  evaluationCycles        EvaluationCycle[]
  playerEvaluations       PlayerEvaluation[]
  developmentGoals        DevelopmentGoal[]
  notifications           Notification[]
  auditLogs               AuditLog[]

  @@index([status])
  @@index([name])
  @@map("clubs")
}

model ClubSetting {
  id                             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId                         String   @unique @map("club_id") @db.Uuid
  allowParentToParentChat        Boolean  @default(false) @map("allow_parent_to_parent_chat")
  allowParentChildEvaluationView Boolean  @default(false) @map("allow_parent_child_evaluation_view")
  showPlayerPhotosToParents      Boolean  @default(true) @map("show_player_photos_to_parents")
  enableAiFeatures               Boolean  @default(true) @map("enable_ai_features")
  enableSmsNotifications         Boolean  @default(false) @map("enable_sms_notifications")
  defaultCurrency                String   @default("USD") @map("default_currency") @db.VarChar(10)
  attendanceTrackingEnabled      Boolean  @default(true) @map("attendance_tracking_enabled")
  registrationEnabled            Boolean  @default(true) @map("registration_enabled")
  billingEnabled                 Boolean  @default(true) @map("billing_enabled")
  createdAt                      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id])

  @@map("club_settings")
}

model Season {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  name      String   @db.VarChar(150)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid

  club                  Club                   @relation(fields: [clubId], references: [id])
  teams                 Team[]
  playerTeamMemberships PlayerTeamMembership[]
  registrationPrograms  RegistrationProgram[]
  evaluationCycles      EvaluationCycle[]

  @@index([clubId])
  @@index([status])
  @@map("seasons")
}

model Team {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String    @map("club_id") @db.Uuid
  seasonId           String?   @map("season_id") @db.Uuid
  name               String    @db.VarChar(150)
  teamCode           String    @map("team_code") @db.VarChar(50)
  ageGroup           String?   @map("age_group") @db.VarChar(50)
  division           String?   @db.VarChar(100)
  competitiveLevel   String?   @map("competitive_level") @db.VarChar(100)
  status             String    @default("ACTIVE") @db.VarChar(50)
  primaryCoachUserId String?   @map("primary_coach_user_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy          String?   @map("created_by") @db.Uuid
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy          String?   @map("updated_by") @db.Uuid
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy          String?   @map("deleted_by") @db.Uuid

  club                  Club                   @relation(fields: [clubId], references: [id])
  season                Season?                @relation(fields: [seasonId], references: [id])
  userRoleAssignments   UserRoleAssignment[]
  invitations           Invitation[]
  teamCoaches           TeamCoach[]
  playerTeamMemberships PlayerTeamMembership[]
  announcements         Announcement[]
  chats                 Chat[]
  events                Event[]
  evaluationCycles      EvaluationCycle[]
  playerEvaluations     PlayerEvaluation[]
  developmentGoals      DevelopmentGoal[]

  @@unique([clubId, teamCode], name: "uq_teams_club_team_code")
  @@index([clubId])
  @@index([seasonId])
  @@index([status])
  @@map("teams")
}

model TeamCoach {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleType  String   @map("role_type") @db.VarChar(50)
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid

  club Club @relation(fields: [clubId], references: [id])
  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([clubId])
  @@index([teamId])
  @@index([userId])
  @@map("team_coaches")
}

// =============================================================================
// MODULE: roster — players, memberships, parents, linkage               §7.11–7.14
// =============================================================================

model Player {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId                String    @map("club_id") @db.Uuid
  firstName             String    @map("first_name") @db.VarChar(100)
  lastName              String    @map("last_name") @db.VarChar(100)
  preferredName         String?   @map("preferred_name") @db.VarChar(100)
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  photoUrl              String?   @map("photo_url")
  jerseyNumber          String?   @map("jersey_number") @db.VarChar(20)
  primaryPosition       String?   @map("primary_position") @db.VarChar(50)
  secondaryPosition     String?   @map("secondary_position") @db.VarChar(50)
  medicalNotes          String?   @map("medical_notes")
  allergyNotes          String?   @map("allergy_notes")
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(200)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(30)
  status                String    @default("ACTIVE") @db.VarChar(50)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy             String?   @map("created_by") @db.Uuid
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy             String?   @map("updated_by") @db.Uuid
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy             String?   @map("deleted_by") @db.Uuid

  club                    Club                     @relation(fields: [clubId], references: [id])
  teamMemberships         PlayerTeamMembership[]
  parentLinks             PlayerParentLink[]
  eventRsvps              EventRsvp[]
  attendanceRecords       AttendanceRecord[]
  registrationSubmissions RegistrationSubmission[]
  invoices                Invoice[]
  waiverAcceptances       WaiverAcceptance[]
  evaluations             PlayerEvaluation[]
  developmentGoals        DevelopmentGoal[]

  @@index([clubId])
  @@index([status])
  @@index([lastName, firstName])
  @@index([primaryPosition])
  @@map("players")
}

model PlayerTeamMembership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String    @map("club_id") @db.Uuid
  playerId  String    @map("player_id") @db.Uuid
  teamId    String    @map("team_id") @db.Uuid
  seasonId  String?   @map("season_id") @db.Uuid
  status    String    @default("ACTIVE") @db.VarChar(50)
  joinedAt  DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt    DateTime? @map("left_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid

  club   Club    @relation(fields: [clubId], references: [id])
  player Player  @relation(fields: [playerId], references: [id])
  team   Team    @relation(fields: [teamId], references: [id])
  season Season? @relation(fields: [seasonId], references: [id])

  @@unique([playerId, teamId, seasonId], name: "uq_player_team_memberships")
  @@index([clubId])
  @@index([teamId])
  @@index([playerId])
  @@map("player_team_memberships")
}

model Parent {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId                 String   @map("club_id") @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  firstName              String   @map("first_name") @db.VarChar(100)
  lastName               String   @map("last_name") @db.VarChar(100)
  email                  String   @db.Citext
  phone                  String?  @db.VarChar(30)
  secondaryPhone         String?  @map("secondary_phone") @db.VarChar(30)
  preferredContactMethod String?  @map("preferred_contact_method") @db.VarChar(30)
  addressLine1           String?  @map("address_line1") @db.VarChar(200)
  addressLine2           String?  @map("address_line2") @db.VarChar(200)
  city                   String?  @db.VarChar(100)
  state                  String?  @db.VarChar(100)
  postalCode             String?  @map("postal_code") @db.VarChar(20)
  status                 String   @default("ACTIVE") @db.VarChar(50)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy              String?  @map("created_by") @db.Uuid
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy              String?  @map("updated_by") @db.Uuid

  club                    Club               @relation(fields: [clubId], references: [id])
  user                    User               @relation(fields: [userId], references: [id])
  playerLinks             PlayerParentLink[]
  familyAccountsAsPrimary FamilyAccount[]
  invoices                Invoice[]

  @@unique([clubId, userId], name: "uq_parents_club_user")
  @@index([clubId])
  @@index([userId])
  @@index([email])
  @@map("parents")
}

model PlayerParentLink {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId            String   @map("club_id") @db.Uuid
  playerId          String   @map("player_id") @db.Uuid
  parentId          String   @map("parent_id") @db.Uuid
  relationshipType  String   @map("relationship_type") @db.VarChar(50)
  isPrimaryGuardian Boolean  @default(false) @map("is_primary_guardian")
  canPickup         Boolean  @default(false) @map("can_pickup")
  canPay            Boolean  @default(true) @map("can_pay")
  status            String   @default("ACTIVE") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy         String?  @map("created_by") @db.Uuid

  club   Club   @relation(fields: [clubId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
  parent Parent @relation(fields: [parentId], references: [id])

  @@unique([playerId, parentId], name: "uq_player_parent_link")
  @@index([clubId])
  @@index([playerId])
  @@index([parentId])
  @@map("player_parent_links")
}

// =============================================================================
// MODULE: comms — files, announcements, chats, messages                 §7.15–7.20
// =============================================================================

model File {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String   @map("club_id") @db.Uuid
  ownerUserId  String?  @map("owner_user_id") @db.Uuid
  storageKey   String   @map("storage_key")
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(150)
  sizeBytes    BigInt   @map("size_bytes")
  purpose      String   @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  club               Club                @relation(fields: [clubId], references: [id])
  messageAttachments MessageAttachment[]
  eventAttachments   EventAttachment[]

  @@index([clubId])
  @@index([purpose])
  @@map("files")
}

model Announcement {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String    @map("club_id") @db.Uuid
  teamId       String?   @map("team_id") @db.Uuid
  title        String    @db.VarChar(250)
  body         String
  audienceType String    @map("audience_type") @db.VarChar(50)
  publishedAt  DateTime? @map("published_at") @db.Timestamptz(6)
  status       String    @default("DRAFT") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?   @map("updated_by") @db.Uuid

  club Club  @relation(fields: [clubId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@index([clubId])
  @@index([teamId])
  @@index([status])
  @@index([publishedAt(sort: Desc)])
  @@map("announcements")
}

model Chat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  teamId    String?  @map("team_id") @db.Uuid
  chatType  String   @map("chat_type") @db.VarChar(50)
  title     String?  @db.VarChar(200)
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid

  club     Club         @relation(fields: [clubId], references: [id])
  team     Team?        @relation(fields: [teamId], references: [id])
  members  ChatMember[]
  messages Message[]

  @@index([clubId])
  @@index([teamId])
  @@index([chatType])
  @@map("chats")
}

model ChatMember {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId     String    @map("chat_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  memberRole String?   @map("member_role") @db.VarChar(50)
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  mutedUntil DateTime? @map("muted_until") @db.Timestamptz(6)
  status     String    @default("ACTIVE") @db.VarChar(50)

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@map("chat_members")
}

model Message {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId           String    @map("chat_id") @db.Uuid
  senderUserId     String    @map("sender_user_id") @db.Uuid
  body             String
  messageType      String    @default("TEXT") @map("message_type") @db.VarChar(50)
  replyToMessageId String?   @map("reply_to_message_id") @db.Uuid
  editedAt         DateTime? @map("edited_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  chat        Chat                @relation(fields: [chatId], references: [id])
  sender      User                @relation(fields: [senderUserId], references: [id])
  replyTo     Message?            @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies     Message[]           @relation("MessageReplies")
  attachments MessageAttachment[]

  @@index([chatId, createdAt(sort: Desc)])
  @@index([senderUserId])
  @@map("messages")
}

model MessageAttachment {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String @map("message_id") @db.Uuid
  fileId    String @map("file_id") @db.Uuid

  message Message @relation(fields: [messageId], references: [id])
  file    File    @relation(fields: [fileId], references: [id])

  @@unique([messageId, fileId])
  @@map("message_attachments")
}

// =============================================================================
