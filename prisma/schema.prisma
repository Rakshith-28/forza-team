  positionCode       String   @map("position_code") @db.VarChar(50)
  overallScore       Decimal  @map("overall_score") @db.Decimal(8, 2)
  rankInScope        Int?     @map("rank_in_scope")
  bucketLabel        String?  @map("bucket_label") @db.VarChar(50)
  summaryComment     String?  @map("summary_comment")
  coachOnlyNotes     String?  @map("coach_only_notes")
  parentVisibleNotes String?  @map("parent_visible_notes")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy          String?  @map("created_by") @db.Uuid
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy          String?  @map("updated_by") @db.Uuid

  club            Club                    @relation(fields: [clubId], references: [id])
  team            Team                    @relation(fields: [teamId], references: [id])
  player          Player                  @relation(fields: [playerId], references: [id])
  evaluationCycle EvaluationCycle         @relation(fields: [evaluationCycleId], references: [id])
  template        EvaluationTemplate      @relation(fields: [templateId], references: [id])
  scores          PlayerEvaluationScore[]

  @@unique([playerId, evaluationCycleId, templateId], name: "uq_player_evaluations")
  @@index([clubId])
  @@index([teamId])
  @@index([playerId])
  @@index([evaluationCycleId])
  @@index([overallScore(sort: Desc)])
  @@map("player_evaluations")
}

model PlayerEvaluationScore {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerEvaluationId String  @map("player_evaluation_id") @db.Uuid
  criterionId        String  @map("criterion_id") @db.Uuid
  rawScore           Decimal @map("raw_score") @db.Decimal(8, 2)
  weightedScore      Decimal @map("weighted_score") @db.Decimal(8, 2)

  playerEvaluation PlayerEvaluation    @relation(fields: [playerEvaluationId], references: [id], onDelete: Cascade)
  criterion        EvaluationCriterion @relation(fields: [criterionId], references: [id])

  @@unique([playerEvaluationId, criterionId], name: "uq_player_evaluation_score")
  @@index([playerEvaluationId])
  @@index([criterionId])
  @@map("player_evaluation_scores")
}

model DevelopmentGoal {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  playerId    String    @map("player_id") @db.Uuid
  teamId      String?   @map("team_id") @db.Uuid
  title       String    @db.VarChar(200)
  description String?
  category    String?   @db.VarChar(100)
  status      String    @default("OPEN") @db.VarChar(50)
  visibility  String    @default("COACH_ONLY") @db.VarChar(50)
  targetDate  DateTime? @map("target_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?   @map("updated_by") @db.Uuid

  club    Club                    @relation(fields: [clubId], references: [id])
  player  Player                  @relation(fields: [playerId], references: [id])
  team    Team?                   @relation(fields: [teamId], references: [id])
  updates DevelopmentGoalUpdate[]

  @@index([clubId])
  @@index([playerId])
  @@index([status])
  @@map("development_goals")
}

model DevelopmentGoalUpdate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId         String   @map("goal_id") @db.Uuid
  progressStatus String   @map("progress_status") @db.VarChar(50)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?  @map("created_by") @db.Uuid

  goal DevelopmentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("development_goal_updates")
}

// =============================================================================
// Platform: notifications & audit (cross-cutting / reporting)           §7.49–7.51
// =============================================================================

model Notification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  clubId          String?   @map("club_id") @db.Uuid
  type            String    @db.VarChar(100)
  title           String    @db.VarChar(200)
  body            String?
  payloadJson     Json?     @map("payload_json")
  deliveryChannel String    @map("delivery_channel") @db.VarChar(30)
  status          String    @default("PENDING") @db.VarChar(50)
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz(6)
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)
  readAt          DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User  @relation(fields: [userId], references: [id])
  club Club? @relation(fields: [clubId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

model NotificationPreference {
  id                               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                           String   @unique @map("user_id") @db.Uuid
  emailEnabled                     Boolean  @default(true) @map("email_enabled")
  pushEnabled                      Boolean  @default(true) @map("push_enabled")
  smsEnabled                       Boolean  @default(false) @map("sms_enabled")
  chatNotificationsEnabled         Boolean  @default(true) @map("chat_notifications_enabled")
  announcementNotificationsEnabled Boolean  @default(true) @map("announcement_notifications_enabled")
  billingNotificationsEnabled      Boolean  @default(true) @map("billing_notifications_enabled")
  scheduleNotificationsEnabled     Boolean  @default(true) @map("schedule_notifications_enabled")
  createdAt                        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String?  @map("club_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String   @db.VarChar(150)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id") @db.Uuid
  metadataJson Json?    @map("metadata_json")
  ipAddress    String?  @map("ip_address") @db.Inet
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  club Club? @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
