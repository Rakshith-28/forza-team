# Forza Team — environment variables
# Copy to `.env` and fill in. `.env` is gitignored. Validated at startup by
# src/lib/env.ts — the app refuses to boot if any required value is missing.

# --- Database (Neon Postgres) ---------------------------------------------
# Pooled connection (PgBouncer) used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/forza?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection used by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/forza?sslmode=require"

# --- Auth (Better Auth) ---------------------------------------------------
# Generate: `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-32+-char-random-secret"
# Base URL used to build links in invite/reset emails.
BETTER_AUTH_URL="http://localhost:3000"

# --- Rate limiting (Upstash Redis) — OPTIONAL -----------------------------
# Absent ⇒ auth routes are not rate-limited locally (a warning is logged).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Email (Resend) — OPTIONAL --------------------------------------------
# Absent ⇒ emails (invites, password resets) are logged to the console in dev.
RESEND_API_KEY=""
EMAIL_FROM="Forza Team <onboarding@resend.dev>"

# --- File storage ---------------------------------------------------------
# "local" (default in dev, writes to .uploads/) or "blob" (Vercel Blob).
# REQUIRED to be "blob" on serverless (Vercel has no writable disk).
STORAGE_DRIVER="local"
# Required when STORAGE_DRIVER=blob.
BLOB_READ_WRITE_TOKEN=""

# --- Optional ------------------------------------------------------------
# debug | info | warn | error  (defaults: debug in dev, info in prod)
LOG_LEVEL="debug"

# --- Tests — OPTIONAL ------------------------------------------------------
# Isolated DB for `npm run test:integration` (NEVER the shared dev branch).
# When unset, the integration suite skips itself.
# TEST_DATABASE_URL="postgresql://postgres:pw@localhost:5433/postgres"
